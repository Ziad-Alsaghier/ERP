{
    "name": "laravel/laravel",
    "type": "project",
    "description": "The Laravel Framework.",
    "keywords": ["framework", "laravel"],
    "license": "MIT",
    "require": {
        "php": "^8.1",
        "anandsiddharth/laravel-paytm-wallet": "^2.0",
        "anhskohbo/no-captcha": "^3.6",
        "arkitecht/laravel-twilio": "^1.6",
        "coingate/coingate-php": "^4.1",
        "doctrine/dbal": "^3.8.6",
        "endroid/qr-code": "^5.0",
        "guzzlehttp/guzzle": "^7.8.1",
        "iyzico/iyzipay-php": "^2.0.55",
        "kkomelin/laravel-translatable-string-exporter": "^1.22",
        "lab404/laravel-impersonate": "^1.7.5",
        "laravel/framework": "^10.0",
        "laravel/sanctum": "^3.3.3",
        "laravel/telescope": "^5.2",
        "laravel/tinker": "^2.9",
        "laravel/ui": "^4.5.2",
        "laravelcollective/html": "^6.4.1",
        "league/flysystem-aws-s3-v3": "^3.28",
        "maatwebsite/excel": "^3.1.55",
        "mashape/unirest-php": "^3.0.4",
        "mercadopago/dx-php": "^2.6.2",
        "midtrans/midtrans-php": "^2.5.2",
        "milon/barcode": "^10.0.1",
        "mollie/mollie-api-php": "^2.69",
        "munafio/chatify": "1.2",
        "nwidart/laravel-modules": "^9.0.6",
        "obydul/laraskrill": "^1.2",
        "orhanerday/open-ai": "^4.9.1",
        "paymentwall/paymentwall-php": "^2.2.4",
        "paytabscom/laravel_paytabs": "^1.7.1",
        "phpseclib/phpseclib": "^3.0",
        "prgayman/laravel-zatca": "^1.0",
        "psr/simple-cache": "3.0",
        "spatie/browsershot": "^3.61",
        "spatie/laravel-google-calendar": "^3.8",
        "spatie/laravel-permission": "^5.11.1",
        "srmklive/paypal": "^3.0.32",
        "stripe/stripe-php": "^13.18",
        "twilio/sdk": "^6.44.4",
        "whichbrowser/parser": "^2.1.8",
        "xendit/xendit-php": "^2.19",
        "yajra/laravel-datatables-oracle": "^10.11.4",
        "yoomoney/yookassa-sdk-php": "^3.4"
    },
    "require-dev": {
        "barryvdh/laravel-debugbar": "^3.13.5",
        "fakerphp/faker": "^1.23.1",
        "kitloong/laravel-migrations-generator": "^7.0",
        "laravel/pint": "^1.16.1",
        "laravel/sail": "^1.30",
        "mockery/mockery": "^1.6.12",
        "nunomaduro/collision": "^7.10",
        "phpunit/phpunit": "^10.5.24",
        "spatie/laravel-ignition": "^2.8"
    },
    "autoload": {
        "psr-4": {
            "App\\": "app/",
            "Database\\Factories\\": "database/factories/",
            "Database\\Seeders\\": "database/seeders/",
            "Modules\\": "Modules/",
            "NadyShalaby\\Zatca\\": "src/"


        },
        "files": [
            "app/Helpers/LanguageHelper.php"
        ]
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/",
            "ZATCA\\": "Packages/zatca-qr/ZATCA/"
        },
        "files": [
        ]
    },
    "scripts": {
        "post-autoload-dump": [
            "Illuminate\\Foundation\\ComposerScripts::postAutoloadDump",
            "@php artisan package:discover --ansi"
        ],
        "post-update-cmd": [
            "@php artisan vendor:publish --tag=laravel-assets --ansi --force"
        ],
        "post-root-package-install": [
            "@php -r \"file_exists('.env') || copy('.env.example', '.env');\""
        ],
        "post-create-project-cmd": [
            "@php artisan key:generate --ansi"
        ]
    },
    "extra": {
        "laravel": {
            "dont-discover": []
        }
    },
    "config": {
        "optimize-autoloader": true,
        "preferred-install": "dist",
        "sort-packages": true
    },
    "minimum-stability": "dev",
    "prefer-stable": true,
    "repositories": [

    ]
}
